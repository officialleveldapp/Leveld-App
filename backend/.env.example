# Copy to backend/.env for local dev. On Railway, set these in the service variables.

# --- Required in production (DEBUG=False) ---------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Comma-separated; in production include your Railway hostname and any custom domain.
ALLOWED_HOSTS=localhost,127.0.0.1

# When DEBUG=False, set browser origins that may call the API (Expo web, etc.).
# Native iOS/Android apps usually do not need this. Example:
# CORS_ALLOWED_ORIGINS=https://your-app.example.com

# --- Database -------------------------------------------------------------
# Railway Postgres: paste the DATABASE_URL variable (recommended).
# DATABASE_URL=postgres://...

# Local / discrete variables (used only if DATABASE_URL is unset):
DB_NAME=leveld
DB_USER=rahbe
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Optional -------------------------------------------------------------
# iOS Google Sign-In: same iOS OAuth CLIENT_ID as EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID (comma-separated if multiple).
GOOGLE_OAUTH_CLIENT_IDS=

# Sign in with Apple: bundle ID(s) that may appear as the token audience (defaults to com.rahbe.leveld).
# APPLE_SIGNIN_CLIENT_IDS=com.rahbe.leveld

# RevenueCat webhook: same value as Authorization Bearer in the RC dashboard.
# REVENUECAT_WEBHOOK_SECRET=

# Optional: set true to force Django HTTP→HTTPS redirects (often unnecessary on Railway).
# SECURE_SSL_REDIRECT=False

# Optional: required only if you add Firebase Admin / GCP SDK server features.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
