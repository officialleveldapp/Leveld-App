EXPO_PUBLIC_API_URL=http://localhost:8001/api

# iOS Google Sign-In — CLIENT_ID from Google Cloud (iOS OAuth client) or GoogleService-Info.plist.
# Requires a NATIVE build: npx expo run:ios (not Expo Go). See docs/GOOGLE_SIGNIN_IOS.md
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Superwall — Dashboard → Settings → Keys → Public API Key (iOS). Requires dev build: npx expo run:ios
EXPO_PUBLIC_SUPERWALL_IOS_KEY=
# Optional Android public key
# EXPO_PUBLIC_SUPERWALL_ANDROID_KEY=
# Placement after onboarding (app default is campaign_trigger if unset)
EXPO_PUBLIC_SUPERWALL_ONBOARDING_PLACEMENT=campaign_trigger
# With __DEV__: developer API + verbose SDK logs
EXPO_PUBLIC_SUPERWALL_DEBUG=1

# RevenueCat (native dev / store builds). Dashboard → API Keys → Public app-specific key.
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
# EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=
# EXPO_PUBLIC_RC_PRODUCT_MONTHLY=monthly
# EXPO_PUBLIC_RC_PRODUCT_YEARLY=yearly
# EXPO_PUBLIC_RC_PRODUCT_LIFETIME=lifetime
# Optional — Pro paywall footer links
# EXPO_PUBLIC_LEGAL_TERMS_URL=https://example.com/terms
# EXPO_PUBLIC_LEGAL_PRIVACY_URL=https://example.com/privacy
