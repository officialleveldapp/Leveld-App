{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "leveld-landing",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "routes": [
    { "pattern": "leveldai.com", "custom_domain": true },
    { "pattern": "www.leveldai.com", "custom_domain": true },
  ],
}
